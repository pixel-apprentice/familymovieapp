rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to validate ratings
    function isValidRatings(ratings) {
      return ratings.Jack >= 0 && ratings.Jack <= 5 &&
             ratings.Simone >= 0 && ratings.Simone <= 5 &&
             ratings.Mom >= 0 && ratings.Mom <= 5 &&
             ratings.Dad >= 0 && ratings.Dad <= 5 &&
             // Ensure they are integers (or floats that equal their integer part)
             ratings.Jack % 1 == 0 &&
             ratings.Simone % 1 == 0 &&
             ratings.Mom % 1 == 0 &&
             ratings.Dad % 1 == 0;
    }

    match /movies/{movieId} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create, but must have valid ratings if watched
      allow create: if isAuthenticated() && 
                    (request.resource.data.status == 'wishlist' || 
                    (request.resource.data.status == 'watched' && isValidRatings(request.resource.data.ratings)));
      
      // Anyone authenticated can update, must have valid ratings if watched
      allow update: if isAuthenticated() && 
                    (request.resource.data.status == 'wishlist' || 
                    (request.resource.data.status == 'watched' && isValidRatings(request.resource.data.ratings)));
      
      // Anyone authenticated can delete
      allow delete: if isAuthenticated();
    }

    match /metadata/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
